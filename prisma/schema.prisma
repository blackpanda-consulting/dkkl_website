// DKKL (Kashi Laabh) — data model
// See ../../IMPLEMENTATION_PLAN.md §3. All money is stored in paise (integers).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Singleton row (id = 1) holding admin-editable pricing. Spec §7: the rate must
// be editable without a code deploy.
model Setting {
  id              Int @id @default(1)
  singleRatePaise Int @default(2500000) // ₹25,000 single occupancy
  doubleRatePaise Int @default(3000000) // ₹30,000 double occupancy
  sharedRatePaise Int @default(1800000) // ₹18,000 shared occupancy
  // Legacy columns kept (unused) to avoid destructive drops.
  monthlyRatePaise Int      @default(3000000)
  depositPaise     Int      @default(0)
  updatedAt        DateTime @updatedAt
  updatedBy        String?
}

model Booking {
  id         String @id @default(cuid())
  bookingRef String @unique // human ref, e.g. KL-2026-000123

  // Resident + family details (spec §8)
  familyName        String
  familyMobile      String
  residentName      String
  residentAge       Int
  condition         Condition
  mobility          Mobility
  arrivalDate       DateTime
  attendantName     String
  attendantRelation String
  longTermConfirmed Boolean
  consentAccepted   Boolean

  // Pricing snapshot — server-computed at order time (spec §12)
  roomType         RoomType @default(DOUBLE)
  months           Int
  monthlyRatePaise Int // the selected room's monthly rate
  depositPaise     Int      @default(0) // retained column, no longer used
  amountPaise      Int

  // Razorpay
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  status            BookingStatus @default(PROVISIONAL)
  refundId          String?
  refundStatus      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Idempotency ledger for Razorpay webhooks (spec §12)
model WebhookEvent {
  id          String   @id // razorpay event id
  type        String
  processedAt DateTime @default(now())
}

// Monotonic counter used to generate human booking references safely under
// concurrency (spec §4).
model Counter {
  year Int @id
  seq  Int @default(0)
}

// Qualified-enquiry / consultation requests from the contact form (spec §1:
// "Generate qualified long-term-stay enquiries").
model Enquiry {
  id            String   @id @default(cuid())
  name          String
  mobile        String
  email         String?
  preferredStay String? // e.g. "1-3 months", "Not sure yet"
  message       String?
  handled       Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

enum RoomType {
  SINGLE
  DOUBLE
  SHARED
  TWIN // legacy value kept to avoid destructive enum change; no longer used
}

enum Condition {
  TERMINALLY_ILL
  ELDERLY_FRAIL
  OTHER
}

enum Mobility {
  INDEPENDENT
  ASSISTED
  BEDRIDDEN
}

enum BookingStatus {
  PROVISIONAL
  PENDING
  FAILED
  PAID_PENDING_ADMISSION // "Paid - Pending Final Admission Confirmation"
  REFUND_INITIATED
  REFUND_COMPLETED
}
