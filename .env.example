# ---------------------------------------------------------------------------
# DKKL (Kashi Laabh) — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ---------------------------------------------------------------------------

# Neon Postgres. Use the POOLED connection string for the app.
# Get from Neon dashboard -> Connection Details -> "Pooled connection".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/dkkl?sslmode=require"

# Razorpay hosted payment link for the flat booking fee. This is what the site
# actually uses today: the "Book a slot" CTA links straight to it. Until it is
# set, the CTA falls back to asking the family to call.
NEXT_PUBLIC_BOOKING_LINK="https://rzp.io/l/xxxxxxxx"

# ---------------------------------------------------------------------------
# The keys below drive the per-booking Orders API flow (/api/orders, /api/verify,
# /api/razorpay/webhook). That flow is built and tested but currently DORMANT —
# nothing in the UI calls it while booking is a flat fee via the link above.
# Fill these in to charge per-booking amounts again.
# ---------------------------------------------------------------------------

# Razorpay (Dashboard -> Settings -> API Keys). Use TEST keys in development.
# The key id reaches the browser through /api/orders, so no NEXT_PUBLIC_ copy is needed.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
# Webhook secret from Razorpay Dashboard -> Settings -> Webhooks.
# Register the endpoint as: <NEXT_PUBLIC_SITE_URL>/api/razorpay/webhook
# Subscribe it to: payment.captured, payment.failed, refund.processed, refund.failed
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"

# Admin panel gate (single shared password for DKKL staff). Change before launch.
ADMIN_PASSWORD="change-me-strong-password"
# Secret used to sign the admin session cookie.
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# Public site URL (used in confirmations / absolute links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Business contact details shown in Call / WhatsApp CTAs.
NEXT_PUBLIC_PHONE="+910000000000"
NEXT_PUBLIC_WHATSAPP="910000000000"
